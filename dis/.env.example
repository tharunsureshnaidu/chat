# ── Database (local postgres) ─────────────────────────────────────────────────

DATABASE_URL=postgres://dis:dis@localhost:5432/dis

DB_POOL_MAX_CONNECTIONS=100

DB_POOL_MIN_CONNECTIONS=5



# ── Redis (docker compose) ────────────────────────────────────────────────────

REDIS_URL=redis://localhost:6379

REDIS_POOL_SIZE=20



# ── Kafka (docker compose) ────────────────────────────────────────────────────

KAFKA_BROKERS=localhost:9092

KAFKA_TOPIC=chat_messages

KAFKA_CONSUMER_GROUP=dis-persistence

KAFKA_NOTIFICATION_GROUP=dis-notifications



# ── JWT ───────────────────────────────────────────────────────────────────────

JWT_SECRET=change_me_to_a_long_random_secret

JWT_EXPIRY_HOURS=24



# ── Server ────────────────────────────────────────────────────────────────────

SERVER_HOST=0.0.0.0

SERVER_PORT=3000



# ── Presence ──────────────────────────────────────────────────────────────────

PRESENCE_HEARTBEAT_SECS=30

PRESENCE_TTL_SECS=60



# ── Security (leave empty for local dev = permissive CORS) ────────────────────

ALLOWED_ORIGINS=

BODY_LIMIT_BYTES=524288